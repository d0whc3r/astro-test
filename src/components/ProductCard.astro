---
import BaseImage from './BaseImage.astro';

interface Props {
  image: string;
  alt: string;
  title: string;
  description: string;
  href: string;
  linkText: string;
  titleKey?: string;
  descriptionKey?: string;
  linkTextKey?: string;
}

const { image, alt, title, description, href, linkText, titleKey, descriptionKey, linkTextKey } = Astro.props;
---

<section class="box special alt" aria-labelledby={`product-${titleKey || title}`}>
  <span class="image featured">
    <BaseImage src={image} alt={alt} loading="lazy" width={600} height={340} />
  </span>
  <h3 id={`product-${titleKey || title}`} data-i18n={titleKey}>{title}</h3>
  <p data-i18n={descriptionKey}>{description}</p>
  <ul class="actions special">
    <li><a href={href} class="button alt" data-i18n={linkTextKey}>{linkText}</a></li>
  </ul>
</section>
