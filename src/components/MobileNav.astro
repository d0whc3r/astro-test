---
import NavLink from './NavLink.astro';
---

<div id="navButton" role="button" aria-label="Toggle navigation menu">
  <a href="#navPanel" class="toggle" aria-expanded="false" aria-controls="navPanel"></a>
</div>

<div id="navPanel" role="navigation" aria-label="Mobile navigation">
  <nav>
    <a class="link depth-0" href="?lang=es"><span class="indent-0"></span><span>es</span></a>
    <a class="link depth-0" href="?lang=en"><span class="indent-0"></span><span>en</span></a>
    <a class="link depth-0" href="?lang=ca"><span class="indent-0"></span><span>ca</span></a>
    <NavLink class="link depth-1" href="/"><span class="indent-1"></span><span data-i18n="home">Home</span></NavLink>
    <NavLink class="link depth-1" href="/products/fans/"
      ><span class="indent-1"></span><span data-i18n="products-fans-title">Ventilation</span></NavLink
    >
    <NavLink class="link depth-2" href="/products/fans/duct/"
      ><span class="indent-2"></span><span data-i18n="products-fans-duct">Axial</span></NavLink
    >
    <NavLink class="link depth-2" href="/products/fans/radial/"
      ><span class="indent-2"></span><span data-i18n="products-fans-radial">Centrifugal</span></NavLink
    >
    <NavLink class="link depth-2" href="/products/fans/roof/"
      ><span class="indent-2"></span><span data-i18n="products-fans-roof">Roof</span></NavLink
    >
    <NavLink class="link depth-1" href="/products/filters/"
      ><span class="indent-1"></span><span data-i18n="products-filters-title">Filtration</span></NavLink
    >
    <NavLink class="link depth-2" href="/products/filters/dust/"
      ><span class="indent-2"></span><span data-i18n="products-filters-dust">Particles</span></NavLink
    >
    <NavLink class="link depth-2" href="/products/filters/liquid/"
      ><span class="indent-2"></span><span data-i18n="products-filters-liquid">Liquids</span></NavLink
    >
    <NavLink class="link depth-2" href="/products/filters/air/"
      ><span class="indent-2"></span><span data-i18n="products-filters-air">Gases</span></NavLink
    >
    <NavLink class="link depth-1" href="/solutions360/"
      ><span class="indent-1"></span><span data-i18n="solutions360">Solutions 360º</span></NavLink
    >
    <NavLink class="link depth-1" href="/team/"
      ><span class="indent-1"></span><span data-i18n="about">About Us</span></NavLink
    >
  </nav>
</div>

<script>
  const navButton = document.getElementById('navButton');
  const navPanel = document.getElementById('navPanel');
  const body = document.body;
  const toggle = navButton?.querySelector<HTMLElement>('.toggle');

  function openPanel() {
    body.classList.add('navPanel-visible');
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closePanel() {
    body.classList.remove('navPanel-visible');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  if (navButton && toggle) {
    toggle.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (body.classList.contains('navPanel-visible')) {
        closePanel();
      } else {
        openPanel();
      }
    });

    // Keyboard support
    toggle.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        e.preventDefault();
        closePanel();
        toggle.focus();
      }
    });
  }

  document.addEventListener('click', (e: MouseEvent) => {
    if (body.classList.contains('navPanel-visible')) {
      const target = e.target as Node | null;
      const panelNode = navPanel as Node | null;
      const buttonNode = navButton as Node | null;
      if (panelNode && !panelNode.contains(target) && buttonNode && !buttonNode.contains(target)) {
        closePanel();
      }
    }
  });

  // Close panel when a link is clicked
  if (navPanel) {
    navPanel.querySelectorAll('a, [href]').forEach((link) => {
      link.addEventListener('click', () => closePanel());
    });
  }
</script>

<style>
  @reference "../styles/global.css";
  /* ── Mobile nav ──────────────────────────────────────────── */

  #navPanel,
  #navButton {
    @apply hidden;
  }

  /* ── Responsive: Narrower (≤ 840px) ─────────────────────── */

  @media screen and (max-width: 840px) {
    html,
    body {
      @apply overflow-x-clip;
    }
    body,
    input,
    select,
    textarea {
      font-size: 11pt;
    }

    header.major {
      @apply px-[4em] py-0;
    }

    .box {
      @apply p-[3em_2em];
    }
    .box .image.featured {
      @apply -ml-[2em] w-[calc(100%+4em)];
    }
    .box .image.featured:first-child {
      @apply -mt-[3em] mb-[3em];
    }
    .box .image.featured:last-child {
      @apply mt-[3em] -mb-[3em];
    }
    .box.special {
      @apply min-h-[300px];
    }
    .row .box .image.featured img {
      @apply max-h-[250px] object-cover;
    }

    #page-wrapper {
      @apply pt-0 pb-px transition-transform duration-500 ease-in-out backface-hidden;
    }

    #header {
      @apply hidden;
    }

    .contact-block h3 {
      @apply text-[1.5em];
    }
    .contact-block ul {
      @apply ml-[38%];
    }
    .contact-block ul li {
      @apply text-[1.1em];
    }

    /* Mobile nav button */
    #navButton {
      @apply transition-transform duration-500 ease-in-out backface-hidden;
      @apply fixed top-0 left-0 z-[10001] block h-[44px] w-full;
    }

    #navButton .toggle {
      @apply absolute top-0 left-0 block h-full w-full border-0 no-underline outline-none;
    }

    #navButton .toggle:before {
      @apply block font-black not-italic antialiased;
      font-family: 'Font Awesome 6 Free', 'Font Awesome 5 Free';
      @apply rounded-[6px] bg-[rgba(192,192,192,0.75)] text-white;
      content: '\f0c9';
      @apply absolute top-[0.5em] left-[0.5em] h-[2.25em] w-[3.5em] text-center text-[16px] leading-[2.25em];
    }

    /* Mobile nav panel */
    #navPanel {
      @apply -translate-x-[275px] transition-transform duration-500 ease-in-out backface-hidden;
      @apply fixed top-0 left-0 z-[10002] block h-full w-[275px] overflow-y-auto;
      @apply bg-nav text-faded;
    }

    #navPanel .link {
      @apply block h-[44px] border-t border-b-0 border-solid border-white/5 px-[1em] leading-[44px] text-faded no-underline;
    }

    #navPanel .link:first-child {
      @apply border-t-0;
    }
    #navPanel .link.depth-0 {
      @apply font-normal text-white;
    }
    #navPanel .link .indent-1 {
      @apply inline-block w-[1em];
    }
    #navPanel .link .indent-2 {
      @apply inline-block w-[2em];
    }
    #navPanel .link .indent-3 {
      @apply inline-block w-[3em];
    }

    body.navPanel-visible #page-wrapper {
      @apply translate-x-[275px];
    }
    body.navPanel-visible #navButton {
      @apply translate-x-[275px];
    }
    body.navPanel-visible #navPanel {
      @apply translate-x-0;
    }

    .row > .col-12-narrower {
      @apply w-full;
    }
    .row > .col-6-narrower {
      @apply w-1/2;
    }
    .container {
      width: 100% !important;
    }
  }

  /* ── Responsive: Narrow (≤ 980px) ───────────────────────── */

  @media screen and (max-width: 980px) {
    body,
    input,
    select,
    textarea {
      font-size: 11pt;
    }
    .row > .col-12-narrower {
      @apply w-full;
    }
    .row > .col-6-narrower {
      @apply w-1/2;
    }
  }
</style>
