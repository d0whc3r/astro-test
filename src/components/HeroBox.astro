---
import BaseImage from './BaseImage.astro';
---

<section class="box special" aria-labelledby="hero-heading">
  <header class="major">
    <h2 id="hero-heading" data-i18n="hero-title">Industrial solutions for corrosive environments</h2>
    <p data-i18n="hero-description">
      We design and market systems for gas ventilation and filtration, as well as other equipment related to fluid
      handling and storage.
    </p>
  </header>
  <span class="image featured">
    <BaseImage
      src="/images/factory.jpg"
      alt="EcoAir Plastics manufacturing facility with technical plastic components"
      loading="eager"
      fetchpriority="high"
      width={1200}
      height={340}
    />
  </span>
</section>
