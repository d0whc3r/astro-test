---
import NavLink from '../components/NavLink.astro';
---

<div
  id="cookie-banner"
  role="dialog"
  aria-labelledby="cookie-banner-title"
  aria-describedby="cookie-banner-desc"
  aria-modal="false"
>
  <div class="cookie-inner">
    <div class="cookie-text">
      <span id="cookie-banner-desc" data-i18n="cookies-title">
        This website uses own cookies and from third parties (Google Ads) for analytical purposes. You can get more
        information in our
      </span>
      <NavLink href="/legal/#politica-cookies" data-i18n="cookies-link"> Cookies Policy </NavLink>.
    </div>
    <div class="cookie-actions">
      <button id="cookie-accept" type="button" data-i18n="cookies-accept" aria-label="Accept all cookies">
        Accept all
      </button>
      <button id="cookie-reject" type="button" data-i18n="cookies-reject" aria-label="Reject all cookies">
        Reject
      </button>
    </div>
  </div>
</div>

<script>
  function getCookie(name: string): string | null {
    const value = '; ' + document.cookie;
    const parts = value.split('; ' + name + '=');
    if (parts.length === 2) {
      const last = parts.pop();
      return last ? (last.split(';').shift() ?? null) : null;
    }
    return null;
  }

  function setCookie(name: string, val: string, days: number): void {
    const maxAge = days * 24 * 60 * 60;
    document.cookie = name + '=' + val + '; max-age=' + maxAge + '; path=/; SameSite=Lax';
  }

  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const rejectBtn = document.getElementById('cookie-reject');

  if (banner) {
    if (!getCookie('cookie-consent')) {
      banner.style.display = 'block';
    }

    acceptBtn?.addEventListener('click', () => {
      banner.style.display = 'none';
      setCookie('cookie-consent', 'accepted', 365);
    });

    rejectBtn?.addEventListener('click', () => {
      banner.style.display = 'none';
      setCookie('cookie-consent', 'rejected', 365);
    });

    // Keyboard support: Escape dismisses banner when focused
    banner.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        banner.style.display = 'none';
        if (!getCookie('cookie-consent')) {
          setCookie('cookie-consent', 'rejected', 365);
        }
      }
    });
  }
</script>

<style>
  @reference "../styles/global.css";
  /* ── Cookie banner ───────────────────────────────────────── */

  #cookie-banner {
    @apply fixed right-0 bottom-0 left-0 z-[9999] hidden bg-cookie p-[15px] text-[14px] text-white;
  }

  #cookie-banner .cookie-inner {
    @apply mx-auto flex max-w-[960px] flex-wrap items-center justify-between gap-[10px];
  }

  #cookie-banner .cookie-text {
    flex: 1 1 250px;
  }

  #cookie-banner .cookie-text a {
    @apply text-primary;
    border-bottom: dotted 1px;
  }

  #cookie-banner .cookie-actions {
    @apply flex flex-wrap gap-[10px];
  }

  #cookie-accept,
  #cookie-reject {
    @apply cursor-pointer rounded-[4px] border-none px-[16px] py-[6px] text-[13px] font-normal;
    font-family: inherit;
  }

  #cookie-accept {
    @apply bg-primary text-white;
  }
  #cookie-reject {
    @apply bg-[#555] text-white;
  }
</style>
