---
import BaseImage from './BaseImage.astro';

interface Props {
  alt?: boolean;
}
const { alt = true } = Astro.props;
---

<header id="header" class={alt ? 'alt' : ''} role="banner">
  <h1>
    <a href="/" aria-label="EcoAir Plastics - Home">
      <BaseImage id="header-logo" src="/images/header-logo.png" alt="EcoAir Plastics logo" width={180} height={45} />
    </a>
  </h1>
  <nav id="nav" aria-label="Main navigation">
    <ul>
      <li class="whitespace-nowrap"><a href="?lang=es" class="button" aria-label="Cambiar a español">es</a></li>
      <li class="whitespace-nowrap"><a href="?lang=en" class="button" aria-label="Switch to English">en</a></li>
      <li class="whitespace-nowrap"><a href="?lang=ca" class="button" aria-label="Canviar a català">ca</a></li>
      <li class="li-opener whitespace-nowrap select-none cursor-pointer">
        <a
          href="#"
          class="icon solid fa-angle-down text-white! border-0!"
          role="button"
          aria-haspopup="true"
          aria-expanded="false"
          aria-label="Open menu"
        >
          &nbsp;Menu
        </a>
        <ul class="dropotron level-0" role="menu">
          <li role="menuitem"><a href="/" data-i18n="home">Home</a></li>
          <li class="li-opener" role="menuitem">
            <a
              href="/products/fans"
              data-i18n="products-fans-title"
              role="button"
              aria-haspopup="true"
              aria-expanded="false"
            >
              Ventilation
            </a>
            <ul class="dropotron level-1 left-auto! right-full! top-0!" role="menu">
              <li role="menuitem"><a href="/products/fans/duct" data-i18n="products-fans-duct">Axial</a></li>
              <li role="menuitem"><a href="/products/fans/radial" data-i18n="products-fans-radial">Centrifugal</a></li>
              <li role="menuitem"><a href="/products/fans/roof" data-i18n="products-fans-roof">Roof</a></li>
            </ul>
          </li>
          <li class="li-opener" role="menuitem">
            <a
              href="/products/filters"
              data-i18n="products-filters-title"
              role="button"
              aria-haspopup="true"
              aria-expanded="false"
            >
              Filtration
            </a>
            <ul class="dropotron level-1 left-auto! right-full! top-0!" role="menu">
              <li role="menuitem"><a href="/products/filters/dust" data-i18n="products-filters-dust">Particles</a></li>
              <li role="menuitem">
                <a href="/products/filters/liquid" data-i18n="products-filters-liquid">Liquids</a>
              </li>
              <li role="menuitem"><a href="/products/filters/air" data-i18n="products-filters-air">Gases</a></li>
            </ul>
          </li>
          <li role="menuitem"><a href="/solutions360" data-i18n="solutions360">Solutions 360º</a></li>
          <li role="menuitem"><a href="/team" data-i18n="about">About Us</a></li>
        </ul>
      </li>
    </ul>
  </nav>
</header>

<script>
  /* ── Header scroll behaviour ─────────────────────── */
  const headerEl = document.getElementById('header');
  const bannerEl = document.getElementById('banner');
  let scrolled = false;

  if (headerEl && bannerEl) {
    const bannerHeight = bannerEl.offsetHeight;

    window.addEventListener('scroll', () => {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;

      if (scrollTop >= bannerHeight) {
        if (!scrolled) {
          scrolled = true;
          headerEl.classList.remove('alt');
          headerEl.classList.add('reveal');
        }
      } else {
        if (scrolled) {
          scrolled = false;
          headerEl.classList.add('alt');
          headerEl.classList.remove('reveal');
        }
      }
    });
  }

  /* ── Desktop dropdown menu ───────────────────────── */
  document.querySelectorAll<HTMLElement>('#nav .li-opener > a[href="#"]').forEach((link) => {
    link.addEventListener('click', (e) => e.preventDefault());
  });

  document.querySelectorAll<HTMLElement>('#nav .li-opener > a').forEach((opener) => {
    opener.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        e.preventDefault();
        opener.focus();
      }
    });
  });
</script>
