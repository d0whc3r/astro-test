---
import Layout from '../layouts/Layout.astro';
import BaseImage from '../components/BaseImage.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import MobileNav from '../components/MobileNav.astro';
import CookieBanner from '../components/CookieBanner.astro';

const title = 'About Us';
const description = 'EcoAir Plastics is a team of engineers specialized in filtration systems.';
---

<Layout title={title} description={description} canonicalUrl="/team" landing={false}>
  <div id="page-wrapper">
    <SiteHeader alt={false} />

    <main id="main-content">
      <section id="main" class="container">
        <header class="major">
          <h2 data-i18n="about">About Us</h2>
        </header>

        <div class="row">
          <div class="col-12">
            <section class="box special">
              <span class="image featured">
                <BaseImage
                  src="/images/team.jpg"
                  alt="EcoAir Plastics engineering team working on filtration systems"
                  loading="lazy"
                  width={1200}
                  height={340}
                />
              </span>
              <h3 data-i18n="team-title">Our team</h3>
              <p data-i18n="team-description">
                We are a team of engineers specialised in filtration systems with over 10 years of combined experience.
              </p>
            </section>
          </div>
        </div>

        <div class="row">
          <div class="col-12">
            <section class="box special">
              <span class="image featured">
                <BaseImage
                  src="/images/factory.jpg"
                  alt="EcoAir Plastics manufacturing facility"
                  loading="lazy"
                  width={1200}
                  height={340}
                />
              </span>
            </section>
          </div>
        </div>
      </section>
    </main>

    <SiteFooter />
    <MobileNav />
    <CookieBanner />
  </div>
</Layout>
