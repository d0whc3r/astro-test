---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import MobileNav from '../components/MobileNav.astro';
import CookieBanner from '../components/CookieBanner.astro';
---

<Layout
  title="About Us | EcoAir Plastics"
  description="Meet the team of engineers behind EcoAir Plastics — specialists in filtration and ventilation systems with over 10 years of combined experience."
  landing={false}
>
  <div id="page-wrapper">
    <SiteHeader alt={false} />

    <section id="main" class="container">
      <header>
        <h2>About us</h2>
        <p>Meet the people behind Ecoairplastics</p>
      </header>

      <!-- Our team -->
      <div class="row">
        <div class="col-6 col-12-narrower">
          <article class="box">
            <h3>Our team</h3>
            <p>
              We are a team of engineers specialised in filtration systems with over 10 years of combined experience.
            </p>
            <p>
              Our team is made up of engineers and technicians specialised in the design and manufacture of industrial
              filtration and ventilation systems. We stand out for providing a service fully adapted to our customers'
              needs.
            </p>
          </article>
        </div>
        <div class="col-6 col-12-narrower">
          <div class="image featured">
            <img src="/images/team.jpg" alt="EcoAir Plastics team" />
          </div>
        </div>
      </div>

      <!-- The company -->
      <div class="row">
        <div class="col-6 col-12-narrower">
          <div class="image featured">
            <img src="/images/factory.jpg" alt="EcoAir Plastics factory" />
          </div>
        </div>
        <div class="col-6 col-12-narrower">
          <article class="box">
            <h3>The company</h3>
            <p>
              Ecoair Plastics is a company with extensive experience in implementing environmental solutions, a key
              factor that has enabled us to market our products and provide our wide range of services not only
              nationally, but also internationally.
            </p>
            <h4>Our services</h4>
            <p>
              We are specialists in air treatment. Our technical team takes care of the capture study, the design of
              suction ducts and the selection of the most suitable treatment system for each situation.
            </p>
            <p>We offer a complete turnkey service from the project, construction and assembly to commissioning.</p>
            <ul class="actions">
              <li><a href="/solutions360.html" class="button alt">Solutions 360º</a></li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <SiteFooter />
    <MobileNav />
    <CookieBanner />
  </div>
</Layout>
