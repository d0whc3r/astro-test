---
import NavLink from '../../../components/NavLink.astro';
import Layout from '../../../layouts/Layout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import MobileNav from '../../../components/MobileNav.astro';
import CookieBanner from '../../../components/CookieBanner.astro';
import BaseImage from '../../../components/BaseImage.astro';
---

<Layout
  title="Centrifugal Fans | EcoAir Plastics"
  description="Plastic centrifugal fans for flow rates from 100 to over 100,000 m³/h. Corrosion-resistant, ATEX-rated, multiple thermoplastic materials."
  landing={false}
>
  <div id="page-wrapper">
    <SiteHeader alt={false} />

    <section id="main" class="container">
      <header>
        <h2>Centrifugal Fans</h2>
        <p>
          We have several fan models for flow rates from 100 to over 100,000 m³/h, low and high pressure.<br />
          Manufactured in various thermoplastics PP, PPs, PPs-el, PVDF, PVC or PE, according to technical requirements.
        </p>
      </header>

      <!-- Specifications -->
      <article class="box">
        <h3>Radial Fans Specifications</h3>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-left">
            <tbody>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark w-1/3">Volume flow</th>
                <td class="py-2">3,000 m³/h – 125,000 m³/h</td>
              </tr>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark">Static pressure</th>
                <td class="py-2">200 Pa – 2,800 Pa</td>
              </tr>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark">Efficiency (tot. mech.)</th>
                <td class="py-2">up to 80%</td>
              </tr>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark">Inlet and outlet ⌀</th>
                <td class="py-2">315 – 1,250 mm</td>
              </tr>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark">Materials</th>
                <td class="py-2">PPs, PPs-el, PVDF, HDPE</td>
              </tr>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark">Drive</th>
                <td class="py-2">Direct, transmission</td>
              </tr>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark">Support</th>
                <td class="py-2">Galvanized, Stainless steel, other</td>
              </tr>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark">Ex Protection</th>
                <td class="py-2">Ex Protection Version available in ATEX zone 1 and 2</td>
              </tr>
            </tbody>
          </table>
        </div>
      </article>

      <!-- PBP model -->
      <div class="row">
        <div class="col-4 col-12-narrower">
          <div class="image featured">
            <BaseImage src="/images/pbp.jpg" alt="PBP Centrifugal Fan" />
          </div>
        </div>
        <div class="col-8 col-12-narrower">
          <article class="box">
            <h3>PBP</h3>
            <p>
              The Ecoair Plastics PBP industrial plastic centrifugal fan is designed for volumes up to 125,000 m³/h. It
              is a robust, highly versatile and reliable fan. Fully customizable for many applications and different
              corrosive media, also for ATEX zones 1 and 2.
            </p>
          </article>
        </div>
      </div>

      <!-- PAP model -->
      <div class="row">
        <div class="col-4 col-12-narrower">
          <div class="image featured">
            <BaseImage src="/images/pap.jpg" alt="PAP Centrifugal Fan" />
          </div>
        </div>
        <div class="col-8 col-12-narrower">
          <article class="box">
            <h3>PAP</h3>
            <p>
              The Ecoair Plastics PAP centrifugal fan is a high-pressure fan for large volumes up to 125,000 m³/h and
              high pressures up to 5,300 Pa. It is a very robust fan, designed for high pressure loads and intended to
              operate in the most adverse continuous service conditions. It can be configured for various applications,
              aggressive gases and also for ATEX zone 1 and 2 areas.
            </p>
          </article>
        </div>
      </div>

      <!-- CMVPro model -->
      <div class="row">
        <div class="col-4 col-12-narrower">
          <div class="image featured">
            <BaseImage src="/images/cmvpro.jpg" alt="CMVPro Centrifugal Fan" />
          </div>
        </div>
        <div class="col-8 col-12-narrower">
          <article class="box">
            <h3>CMVPro</h3>
            <p>
              The Colasit CMVpro® industrial plastic centrifugal fan sets new standards in plastic fan efficiency and
              achieves a notable reduction in your operating costs, even compared to the best competitors. In addition
              to a total mechanical efficiency of up to 83%, the CMVpro® complies with all current and future
              environmental regulations.
            </p>
          </article>
        </div>
      </div>

      <!-- CMVeco model -->
      <div class="row">
        <div class="col-4 col-12-narrower">
          <div class="image featured">
            <BaseImage src="/images/cmveco.jpg" alt="CMVeco Centrifugal Fan" />
          </div>
        </div>
        <div class="col-8 col-12-narrower">
          <article class="box">
            <h3>CMVeco</h3>
            <p>
              The Colasit CMVeco industrial plastic centrifugal fan has been produced since 2009 and is a proven and
              absolutely reliable plastic fan. The CMVeco is available in various materials and drive concepts, and can
              be supplied for most applications with chemically aggressive gases and exhaust air.
            </p>
          </article>
        </div>
      </div>

      <!-- CHVS model -->
      <div class="row">
        <div class="col-4 col-12-narrower">
          <div class="image featured">
            <BaseImage src="/images/chvs.jpg" alt="CHVS Centrifugal Fan" />
          </div>
        </div>
        <div class="col-8 col-12-narrower">
          <article class="box">
            <h3>CHVS</h3>
            <p>
              The Colasit CHVS centrifugal fan is a high-pressure fan for the most demanding requirements, with
              pressures up to 7,000 Pa and volumes up to 5,300 m³/h. This highly reliable and stable plastic fan is
              available in various materials and drive concepts, ensuring it meets any requirement. Additionally, this
              versatile radial fan is suitable for a wide range of applications and different aggressive media,
              including those for hazardous areas in ATEX zone 1 and 2.
            </p>
          </article>
        </div>
      </div>

      <!-- Related products -->
      <div class="row">
        <div class="col-6 col-12-narrower">
          <article class="box">
            <span class="icon solid major fas fa-wind accent4"></span>
            <h3>Axial Fans</h3>
            <p>
              Plastic radial fans, suitable for connection to ventilation pipes in vertical or horizontal arrangement.
            </p>
            <ul class="actions special">
              <li><NavLink href="/products/fans/duct/" class="button alt">More information</NavLink></li>
            </ul>
          </article>
        </div>
        <div class="col-6 col-12-narrower">
          <article class="box">
            <span class="icon solid major fas fa-house accent5"></span>
            <h3>Roof Fans</h3>
            <p>The roof fan with a robust housing made of plastic is weather resistant.</p>
            <ul class="actions special">
              <li><NavLink href="/products/fans/roof/" class="button alt">More information</NavLink></li>
            </ul>
          </article>
        </div>
      </div>

      <article class="box special text-center">
        <h3>All Products</h3>
        <p>Keep exploring our products</p>
        <ul class="actions special">
          <li><NavLink href="/index.html#products" class="button alt">More information</NavLink></li>
        </ul>
      </article>
    </section>

    <SiteFooter />
    <MobileNav />
    <CookieBanner />
  </div>
</Layout>
