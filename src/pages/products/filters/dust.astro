---
import NavLink from '../../../components/NavLink.astro';
import Layout from '../../../layouts/Layout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import MobileNav from '../../../components/MobileNav.astro';
import CookieBanner from '../../../components/CookieBanner.astro';
---

<Layout
  title="Dust Filtration | EcoAir Plastics"
  description="Wet dust treatment technology for high dust loads in aggressive and corrosive industrial environments."
  landing={false}
>
  <div id="page-wrapper">
    <SiteHeader alt={false} />

    <section id="main" class="container">
      <header>
        <h2>Dust filtration</h2>
        <p>Equipment for dust particle filtration.</p>
      </header>

      <article class="box special">
        <p>
          Wet dust treatment technology is commonly used to reduce high dust loads present in gas streams in aggressive
          and corrosive environments that require continuous operating conditions. We design and manufacture the filter
          for each specific application.
        </p>
      </article>

      <!-- Specifications -->
      <article class="box">
        <h3>Specifications</h3>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-left">
            <tbody>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark w-1/3">Capacities</th>
                <td class="py-2">50 m³/h – 200,000 m³/h</td>
              </tr>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark">Type</th>
                <td class="py-2">Hydrocyclone, venturi separator, other</td>
              </tr>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark">Materials</th>
                <td class="py-2">PP, PPs-el, PVDF, HDPE, PVC</td>
              </tr>
              <tr class="border-b border-border">
                <th class="py-2 pr-4 font-semibold text-dark">Applications</th>
                <td class="py-2">Dust treatment, soot, grease and other particles</td>
              </tr>
            </tbody>
          </table>
        </div>
      </article>

      <!-- Related products -->
      <div class="row">
        <div class="col-6 col-12-narrower">
          <article class="box">
            <span class="icon solid major fas fa-wind accent3"></span>
            <h3>Gas filters</h3>
            <p>Systems for gas neutralization and odor control.</p>
            <ul class="actions special">
              <li><NavLink href="/products/filters/air" class="button alt">More information</NavLink></li>
            </ul>
          </article>
        </div>
        <div class="col-6 col-12-narrower">
          <article class="box">
            <span class="icon solid major fas fa-droplet accent4"></span>
            <h3>Liquid filters</h3>
            <p>Liquid filters designed for the removal of solid particles from liquids.</p>
            <ul class="actions special">
              <li><NavLink href="/products/filters/liquid" class="button alt">More information</NavLink></li>
            </ul>
          </article>
        </div>
      </div>

      <article class="box special text-center">
        <h3>All products</h3>
        <p>Explore our products</p>
        <ul class="actions special">
          <li><NavLink href="/index.html#products" class="button alt">More information</NavLink></li>
        </ul>
      </article>
    </section>

    <SiteFooter />
    <MobileNav />
    <CookieBanner />
  </div>
</Layout>
