---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import HeroBanner from '../components/HeroBanner.astro';
import HeroBox from '../components/HeroBox.astro';
import TurnkeySystems from '../components/TurnkeySystems.astro';
import ProductCard from '../components/ProductCard.astro';
import IndustriesGrid from '../components/IndustriesGrid.astro';
import TeamSection from '../components/TeamSection.astro';
import SiteFooter from '../components/SiteFooter.astro';
import MobileNav from '../components/MobileNav.astro';
import CookieBanner from '../components/CookieBanner.astro';
---

<Layout title="EcoAir Plastics | Environmental Solutions for Air Quality" canonicalUrl="/">
  <SiteHeader />

  <HeroBanner
    imageSrc="/images/main-2.jpeg"
    title="EcoAir Plastics"
    subtitle="Environmental Solutions for Air Quality."
  />

  <main id="main-content">
    <section id="main" class="container">
      <HeroBox />
      <TurnkeySystems />

      <div class="row" id="products">
        <div class="col-6 col-12-narrower">
          <ProductCard
            image="/images/fans-1.jpeg"
            alt="Industrial Fans"
            title="Ventilation"
            description="We have our own range of industrial fans manufactured with technical plastics, suitable for working with highly corrosive gases under continuous service conditions."
            href="/products/fans"
            linkText="More information"
            titleKey="fans-title"
            descriptionKey="fans-description"
            linkTextKey="more"
          />
        </div>
        <div class="col-6 col-12-narrower">
          <ProductCard
            image="/images/filters-3.jpg"
            alt="Industrial Filters"
            title="Filtration"
            description="Discover our filtration solutions for the industrial sector. We offer dust, liquid and gas filters adapted to the needs of each process and designed to meet the most stringent requirements."
            href="/products/filters"
            linkText="More information"
            titleKey="filters-title"
            descriptionKey="filters-description"
            linkTextKey="more"
          />
        </div>
      </div>

      <IndustriesGrid />
      <TeamSection />
    </section>
  </main>

  <SiteFooter />
  <MobileNav />
  <CookieBanner />
</Layout>
