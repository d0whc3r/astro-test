{
  "name": "ecoair-plastics",
  "version": "0.0.1",
  "description": "Clone of ecoairplastics.com built with Astro, Tailwind CSS, and AI-assisted development",
  "repository": {
    "type": "git",
    "url": "git@github.com:d0whc3r/astro-test.git"
  },
  "type": "module",
  "scripts": {
    "astro": "astro",
    "build": "astro build",
    "dev": "astro dev",
    "format": "oxfmt --no-error-on-unmatched-pattern --write",
    "format:check": "oxfmt --no-error-on-unmatched-pattern --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix --fix-suggestions --fix-dangerously",
    "preview": "astro preview"
  },
  "dependencies": {
    "astro": "6.1.5",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "@astrojs/sitemap": "3.7.2",
    "@tailwindcss/vite": "4.2.2",
    "autoprefixer": "10.4.27",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "oxlint-tsgolint": "0.20.0"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.28.1"
}
